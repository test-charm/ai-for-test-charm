# ── LLM Configuration ──────────────────────────────────
# Provider: openai | anthropic
CQA_LLM_PROVIDER=openai
CQA_LLM_MODEL=gpt-4o
CQA_LLM_API_KEY=sk-xxx

# For OpenAI-compatible APIs (Ollama, vLLM, LM Studio, etc.)
# CQA_LLM_BASE_URL=http://localhost:11434/v1

# For Anthropic
# CQA_LLM_PROVIDER=anthropic
# CQA_LLM_MODEL=claude-sonnet-4-20250514
# CQA_LLM_API_KEY=sk-ant-xxx

# ── Workspace ──────────────────────────────────────────
# Path to the codebase to analyze (inside container: /workspace)
CQA_WORKSPACE_PATH=/workspace
